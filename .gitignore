# Local tool settings
.claude/settings.local.json

# Cache for dynamic skills (NOT the skills themselves - those should be committed)
.claude/skills/.cache
.codex/skills.local/.cache
.gemini/skills.local/.cache

# Backup files (should not exist with current sync scripts, but just in case)
*.bak

# Cloudflare publish temp dirs
.cloudflare-publish*

# Wrangler
.wrangler/

# Ephemeral validation reports and screenshots (reproducible via /aai-validate-report)
docs/ai/reports/**
!docs/ai/reports/.gitkeep

# Pre-compact context snapshots (auto-generated, ephemeral)
docs/ai/.session-context.md
docs/ai/.pre-compact-state-backup.yaml

# Expert subagent cache (fetched on-demand from VoltAgent registry)
.aai/cache/

# Test outputs
tests/skills/results/
docs/ai/tests/test-runs.jsonl
apps/control-plane/dist/
apps/control-plane/node_modules/
.tmp-control-plane-*/
.tmp-control-plane-build-*/
.tmp-test*.log
.tmp-run-all.log

# OS
.DS_Store
Thumbs.db
