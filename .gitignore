# Local tool settings
.claude/settings.local.json

# Cache for dynamic skills (NOT the skills themselves - those should be committed)
.claude/skills/.cache
.codex/skills.local/.cache
.gemini/skills.local/.cache

# Backup files (should not exist with current sync scripts, but just in case)
*.bak

# Cloudflare publish temp dirs
.cloudflare-publish*

# Wrangler
.wrangler/

# Ephemeral AAI runtime reports and screenshots.
# Keep only the directory placeholder in git. Promote any durable finding
# into project-owned docs outside docs/ai/reports/.
docs/ai/reports/**
!docs/ai/reports/
!docs/ai/reports/.gitkeep

# Work-item briefs (Planning-emitted subagent handoffs, spec-work-item-brief):
# per-dev runtime artifacts like reports — regenerated from
# .aai/templates/BRIEF_TEMPLATE.md on re-plan, never committed.
docs/ai/briefs/**
!docs/ai/briefs/
!docs/ai/briefs/.gitkeep

# TDD evidence logs (red/green/refactor test outputs) — per-dev runtime
# evidence, pruned by METRICS_FLUSH after 7 days. Durable evidence lives
# in AC Status tables and EVENTS.jsonl, not in these logs.
docs/ai/tdd/**
!docs/ai/tdd/
!docs/ai/tdd/.gitkeep

# Loop runtime artifacts (per-tick scratch some loop runs create ad hoc).
# Canonical loop state lives in STATE.yaml/LOOP_TICKS.jsonl (local) and
# EVENTS.jsonl/METRICS.jsonl (committed).
docs/ai/loop/

# Pre-compact context snapshots (auto-generated, ephemeral)
docs/ai/.session-context.md
docs/ai/.pre-compact-state-backup.yaml

# Docs index audit companion (SPEC-0010 / ISSUE-0003): the git-history-dependent
# Orphans + Drift sections relocated out of the committed docs/INDEX.md so the
# committed index is a pure function of on-disk docs (idempotent). Regenerated on
# demand by generate-docs-index.mjs; drift/orphans also reported by docs-audit.mjs.
docs/INDEX.audit.md

# AAI per-dev runtime state (RFC-0001: STATE is per-developer local, never committed).
# Cross-developer visibility lives in docs/ai/EVENTS.jsonl (append-only, committed).
docs/ai/STATE.yaml
docs/ai/LOOP_TICKS.jsonl

# Atomic scope locks (RFC-0004 / SPEC-0004): per-agent-local lease files created
# on demand by .aai/scripts/docs-lock.mjs. They coordinate K parallel subagents
# within ONE orchestrator process tree only, never across machines, so they are
# never committed (the script recreates the directory as needed).
docs/ai/locks/

# Expert subagent cache (fetched on-demand from VoltAgent registry)
.aai/cache/

# Test outputs
tests/skills/results/
docs/ai/tests/test-runs.jsonl

# OS
.DS_Store
Thumbs.db
