# AAI Metrics Ledger — append-only, one JSON object per line (JSONL format)
#
# Each line represents one completed work item flushed from STATE.yaml.
#
# Schema per entry (compact JSON, single line):
#   {
#     "date_utc": "YYYY-MM-DD",
#     "ref_id": "PRD-001",
#     "title": "short description",
#     "human_time_minutes": {"intake": N_or_null, "reviews": N_or_null},
#     "agent_runs": [
#       {"role": "Planning|Implementation|Validation|Remediation",
#        "model_id": "claude-sonnet-4-6",
